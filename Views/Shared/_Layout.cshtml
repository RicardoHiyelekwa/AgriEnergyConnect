@using System.Security.Claims
@{
    Layout = null;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userName = isAuthenticated ? User.FindFirstValue(ClaimTypes.Name) ?? "User" : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agri-Energy Connect</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        body {
            padding-top: 70px;
            background-color: #f8f9fa;
        }

        header h1 {
            font-weight: 700;
            color: #0d6efd;
        }

        footer {
            background: #343a40;
            color: #fff;
            padding: 15px 0;
            text-align: center;
            margin-top: 50px;
        }

        .card {
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
        }
    </style>
</head>
<body>
    <header class="fixed-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light container">
            <a class="navbar-brand fw-bold text-primary" href="/">Agri-Energy Connect</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/Products/Add">Add Product</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Products/List">Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Farmers/Add">Add Farmer</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Farmers/List">Farmers</a></li>

                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link">Hello, @userName</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-danger btn-sm ms-2" href="/Account/Logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Account/Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/RegisterFarmer">Register</a></li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; @DateTime.UtcNow.Year Agri-Energy Connect</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
