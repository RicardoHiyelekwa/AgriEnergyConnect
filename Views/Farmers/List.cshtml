@model IEnumerable<AgriEnergyConnect.Models.Farmer>
@{
    Layout = "_Layout";
}

<h2>Farmers</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No farmers found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Location</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td>@f.Name</td>
                        <td>@f.Email</td>
                        <td>@f.Phone</td>
                        <td>@f.Location</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
