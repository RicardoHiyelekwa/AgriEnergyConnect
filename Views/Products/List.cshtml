@model IEnumerable<AgriEnergyConnect.Models.Product>
@{
    Layout = "_Layout";
}

<h2>Products</h2>

@if (TempData["Err"] != null)
{
    <div class="alert alert-warning">@TempData["Err"]</div>
}

<form class="row g-3 mb-3" method="get">
    @if (ViewBag.Farmers != null)
    {
        <div class="col-md-3">
            <label class="form-label">Farmer</label>
            <select name="farmerId" class="form-select">
                <option value="">-- Select Farmer --</option>
                @foreach (var f in ViewBag.Farmers)
                {
                    <option value="@f.FarmerId" @(ViewBag.FarmerId == f.FarmerId ? "selected" : "")>@f.Name</option>
                }
            </select>
        </div>
    }
    <div class="col-md-2">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control" value="@ViewBag.From" />
    </div>
    <div class="col-md-2">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control" value="@ViewBag.To" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Category</label>
        <input name="category" class="form-control" value="@ViewBag.Category" placeholder="Filter by category" />
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Production Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Category</td>
                        <td>@p.ProductionDate.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
